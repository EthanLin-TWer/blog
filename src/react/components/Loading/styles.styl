.loading-container
  display flex
  justify-content center
  align-items center
  height 100vh

.loading-spinner
  width 36px
  height 36px
  border 4px solid transparent
  border-top-color var(--color-primary)
  border-radius 50%
  animation loading-spin 1.2s ease-in-out infinite

@keyframes loading-spin
  to
    transform rotate(360deg)
