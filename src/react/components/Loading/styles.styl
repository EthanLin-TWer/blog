.loading-container
  display flex
  justify-content center
  align-items center
  height 100vh

.loading-spinner
  width 36px
  height 36px
  border 3px solid #eee
  border-top-color #555
  border-radius 50%
  animation loading-spin 0.7s linear infinite

@keyframes loading-spin
  to
    transform rotate(360deg)
